# Android/IntelliJ
#
build/
.idea
.gradle
local.properties
*.iml
*.hprof
.cxx/
*.keystore
!debug.keystore
.kotlin/
# Android signing credentials — NEVER commit the release keystore or its
# password file. key.properties references the keystore by path + password.
android/key.properties
android/app/release.keystore
android/app/release-*.keystore
# Firebase / Google services config — these carry API keys, even though
# Google docs say they're "public". Keep them out of a public repo.
**/google-services.json
**/GoogleService-Info.plist
# iOS signing / APNs
*.p8
*.p12
*.mobileprovision
*.cer

# node.js
#
node_modules/
npm-debug.log
yarn-error.log

# fastlane
#
# It is recommended to not store the screenshots in the git repo. Instead, use fastlane to re-generate the
# screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# Bundle artifact
*.jsbundle

# Ruby / CocoaPods
**/Pods/
/vendor/bundle/

# Temporary files created by Metro to check the health of the file watcher
.metro-health-check*

# testing
/coverage

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

.claude/*
