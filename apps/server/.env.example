# =============================================================================
# @rtc/server — environment variables
#
# Copy to `.env` for local development. Every var here is validated at import
# time by `src/lib/env.ts` — missing or malformed values crash the server at
# boot, not at request time. Intentional.
#
# On fly.io, set these with `fly secrets set KEY=VALUE`. Never commit real
# values.
# =============================================================================

# ---- Runtime mode ----------------------------------------------------------
# One of: development | test | production
NODE_ENV=development

# HTTP port the Fastify server binds. Fly.io's internal port is 8080 in prod.
PORT=4000

# ---- Postgres (Prisma) -----------------------------------------------------
# Local docker-compose: postgres://rtc:rtc@localhost:5432/rtc
# Neon: take the "pooled" connection string from the dashboard.
# `lib/prisma.ts` appends `connect_timeout=30&pool_timeout=30` automatically
# for Neon cold-start mitigation — do NOT set those here.
DATABASE_URL=postgres://rtc:rtc@localhost:5432/rtc

# ---- Redis -----------------------------------------------------------------
# Used for Socket.IO's Redis adapter (horizontal scale) + the 5-minute
# privacy-settings cache. Upstash works; so does a local `redis-server`.
REDIS_URL=redis://localhost:6379

# ---- JWT -------------------------------------------------------------------
# Both secrets MUST be at least 16 characters. Rotate on compromise.
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_32b_min
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

# ---- Token lifetimes (seconds) ---------------------------------------------
# Defaults in env.ts if unset: access = 15 min, refresh = 30 days.
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=2592000

# ---- CORS (web clients only) -----------------------------------------------
# Comma-separated allowlist. Ignored in development (CORS is permissive).
# Mobile clients don't send an Origin header — only browsers need this.
# Leave empty if you don't have a web client yet.
WEB_ORIGIN=
