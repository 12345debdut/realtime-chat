{
  "name": "realtime-chat",
  "private": true,
  "version": "0.1.0",
  "description": "Realtime chat showcase — React Native + Socket.IO + offline-first",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @rtc/mobile",
    "server": "yarn workspace @rtc/server",
    "contracts": "yarn workspace @rtc/contracts",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "yarn workspaces run typecheck",
    "test": "yarn workspaces run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22",
  "resolutions": {
    "react": "19.2.3",
    "react-native": "0.85.0"
  }
}
