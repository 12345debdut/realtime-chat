{
  "name": "realtime-chat",
  "private": true,
  "version": "0.1.0",
  "description": "Realtime chat showcase — React Native + Socket.IO + offline-first",
  "license": "Apache-2.0",
  "author": "Debdut Saha",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @rtc/mobile",
    "server": "yarn workspace @rtc/server",
    "contracts": "yarn workspace @rtc/contracts",
    "build:contracts": "yarn workspace @rtc/contracts build",
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --build && yarn workspace @rtc/mobile typecheck",
    "test": "yarn workspace @rtc/server test && yarn workspace @rtc/mobile test",
    "ci": "yarn build && yarn lint && yarn typecheck && yarn test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.30.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@3.6.4",
  "resolutions": {
    "react": "19.2.3",
    "react-native": "0.85.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=9999"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
