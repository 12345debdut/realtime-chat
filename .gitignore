# =============================================================================
# Realtime Chat — root .gitignore
#
# Covers the whole monorepo. Per-package gitignores (e.g. apps/mobile/.gitignore)
# handle platform-specific artifacts (Xcode, Gradle, CocoaPods, fastlane).
# =============================================================================

# ---------- Node / package managers ------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# ---------- Yarn 3 (Berry) ----------------------------------------------------
# Keep the vendored binary + plugins, ignore everything else that yarn generates
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# ---------- TypeScript build artifacts ---------------------------------------
dist/
build/
out/
*.tsbuildinfo
**/*.tsbuildinfo
.tsbuildinfo

# ---------- Shared workspace build outputs -----------------------------------
packages/contracts/dist/
apps/server/dist/

# ---------- Environment variables --------------------------------------------
# NEVER commit real secrets. Keep only the template files.
.env
.env.*
!.env.example
!.env.sample
!.env.template

# ---------- Prisma ------------------------------------------------------------
# Keep schema.prisma + migrations/ (source of truth), ignore generated client
apps/server/src/generated/
apps/server/prisma/*.db
apps/server/prisma/*.db-journal

# ---------- Fly.io ------------------------------------------------------------
# fly.toml IS committed. These are per-machine / secret files.
.fly/
fly.*.toml.local

# ---------- Docker ------------------------------------------------------------
# Keep Dockerfile + .dockerignore, ignore compose overrides
docker-compose.override.yml
docker-compose.*.local.yml

# ---------- Logs --------------------------------------------------------------
*.log
logs/
pids/
*.pid
*.seed
*.pid.lock

# ---------- Test / coverage ---------------------------------------------------
coverage/
.nyc_output/
*.lcov
junit.xml
test-results/
playwright-report/

# ---------- Caches ------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.eslintcache
.stylelintcache
.rollup.cache/
.vite/
.swc/

# ---------- Editors / IDEs ----------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.iml
*.ipr
*.iws
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ---------- OS ----------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- React Native / Metro ----------------------------------------------
# apps/mobile/.gitignore handles iOS/Android native caches; these are top-level
# safety nets so Metro's temp files never leak if someone runs it from root.
.metro-health-check*
.haste_cache/
metro.log

# ---------- Misc --------------------------------------------------------------
*.hprof
*.tgz
*.zip
.tmp/
tmp/
temp/

# ---------- Claude Code / agent tooling ---------------------------------------
# Local agent configs, plugin workspaces, and session state. Kept out of the
# public repo because they're per-developer and often include agent-persona
# prompts that aren't meant as product documentation.
.claude/
